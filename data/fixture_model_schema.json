          },
          "confidence": {
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "evidence": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
